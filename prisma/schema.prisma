generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Player {
  id               String                  @id @default(cuid())
  slug             String                  @unique
  name             String
  number           Int
  position         String
  height           String?
  weight           String?
  isActive         Boolean                 @default(true)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  photoUrl         String?
  contactEmail     String?
  gameStats        PlayerGameStat[]
  seasonAggregates PlayerSeasonAggregate[]
  rosterEntries    RosterEntry[]
  rosterSlots      GameRosterPlayer[]
  credential       PlayerCredential?
  invites          PlayerInvite[]
}

model Season {
  id            String         @id @default(cuid())
  name          String         @unique
  year          Int
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime       @default(now())
  seasonLeagues SeasonLeague[]
}

model League {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  organizer     String?
  level         String?
  createdAt     DateTime       @default(now())
  seasonLeagues SeasonLeague[]
}

model SeasonLeague {
  id               String                  @id @default(cuid())
  seasonId         String
  leagueId         String
  createdAt        DateTime                @default(now())
  games            Game[]
  seasonAggregates PlayerSeasonAggregate[]
  rosterEntries    RosterEntry[]
  league           League                  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season           Season                  @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, leagueId])
  @@index([seasonId])
  @@index([leagueId])
}

model Game {
  id             String           @id @default(cuid())
  seasonLeagueId String
  opponent       String
  location       String?
  teamScore      Int
  opponentScore  Int
  result         String
  playedOn       DateTime
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  sourceUrl      String?          @unique(where: raw("(\"sourceUrl\" IS NOT NULL)"))
  youtubeUrl     String?
  round          String           @default("regular")
  offRating      Float?
  defRating      Float?
  broadcastedAt  DateTime?
  seasonLeague   SeasonLeague     @relation(fields: [seasonLeagueId], references: [id], onDelete: Cascade)
  playerStats    PlayerGameStat[]

  @@index([playedOn])
}

model RosterEntry {
  id             String       @id @default(cuid())
  playerId       String
  seasonLeagueId String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  player         Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  seasonLeague   SeasonLeague @relation(fields: [seasonLeagueId], references: [id], onDelete: Cascade)

  @@unique([playerId, seasonLeagueId])
}

model PlayerGameStat {
  id        String   @id @default(cuid())
  playerId  String
  gameId    String
  minutes   Float    @default(0)
  pts       Int      @default(0)
  reb       Int      @default(0)
  ast       Int      @default(0)
  stl       Int      @default(0)
  blk       Int      @default(0)
  tov       Int      @default(0)
  pf        Int      @default(0)
  fgm       Int      @default(0)
  fga       Int      @default(0)
  fg3m      Int      @default(0)
  fg3a      Int      @default(0)
  ftm       Int      @default(0)
  fta       Int      @default(0)
  plusMinus Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orb       Int      @default(0)
  drb       Int      @default(0)
  fg2m      Int      @default(0)
  fg2a      Int      @default(0)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, gameId])
  @@index([gameId])
  @@index([playerId])
}

model PlayerSeasonAggregate {
  id             String       @id @default(cuid())
  playerId       String
  seasonLeagueId String
  gp             Int          @default(0)
  ptsAvg         Float        @default(0)
  rebAvg         Float        @default(0)
  astAvg         Float        @default(0)
  stlAvg         Float        @default(0)
  blkAvg         Float        @default(0)
  toAvg          Float        @default(0)
  pfAvg          Float        @default(0)
  fgPct          Float        @default(0)
  fg3Pct         Float        @default(0)
  ftPct          Float        @default(0)
  tsPct          Float        @default(0)
  minutesAvg     Float        @default(0)
  ptsTotal       Int          @default(0)
  rebTotal       Int          @default(0)
  astTotal       Int          @default(0)
  stlTotal       Int          @default(0)
  updatedAt      DateTime     @updatedAt
  orbAvg         Float        @default(0)
  drbAvg         Float        @default(0)
  fg2Pct         Float        @default(0)
  effAvg         Float        @default(0)
  createdAt      DateTime     @default(now())
  fgmTotal       Int          @default(0)
  fgaTotal       Int          @default(0)
  fg2mTotal      Int          @default(0)
  fg2aTotal      Int          @default(0)
  fg3mTotal      Int          @default(0)
  fg3aTotal      Int          @default(0)
  ftmTotal       Int          @default(0)
  ftaTotal       Int          @default(0)
  player         Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  seasonLeague   SeasonLeague @relation(fields: [seasonLeagueId], references: [id], onDelete: Cascade)

  @@unique([playerId, seasonLeagueId])
  @@index([seasonLeagueId])
}

// Retention: rows are purged after LOCKOUT_TTL_S (15 min) by the cleanup cron.
model LoginAttempt {
  id          String   @id @default(cuid())
  // Stored as SHA-256(ip) - raw IP address is never persisted.
  ip          String   @db.VarChar(64)
  attemptedAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([ip, attemptedAt])
}

model UpcomingGame {
  id             String                  @id @default(cuid())
  opponent       String
  scheduledFor   DateTime
  location       String                  @default("home")
  round          String                  @default("regular")
  competition    String?
  notes          String?
  seasonLeagueId String?
  sourceUrl      String?                 @unique(where: raw("(\"sourceUrl\" IS NOT NULL)"))
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  announcement   GameRosterAnnouncement?

  @@index([scheduledFor])
}

model GameRosterAnnouncement {
  id             String             @id @default(cuid())
  upcomingGameId String             @unique
  message        String?
  publishedAt    DateTime           @default(now())
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  upcomingGame   UpcomingGame       @relation(fields: [upcomingGameId], references: [id], onDelete: Cascade)
  players        GameRosterPlayer[]
}

model GameRosterPlayer {
  id             String                 @id @default(cuid())
  announcementId String
  playerId       String
  note           String?
  createdAt      DateTime               @default(now())
  announcement   GameRosterAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  player         Player                 @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([announcementId, playerId])
  @@index([announcementId])
}

// Retention: unconfirmed rows (confirmedAt IS NULL) are purged after 7 days by the
// cleanup cron (purgeUnconfirmedSubscribers). Confirmed rows are retained until the
// subscriber unsubscribes. Email is stored in plaintext as it is required for delivery.
model Subscriber {
  id            String    @id @default(cuid())
  email         String    @unique
  token         String    @unique
  confirmToken  String?   @unique
  confirmedAt   DateTime?
  lastEmailedAt DateTime?
  createdAt     DateTime  @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model CronRun {
  id         String    @id @default(cuid())
  job        String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  ok         Boolean   @default(false)
  summary    Json?
  error      String?

  @@index([job, startedAt])
}

// Retention: rows older than 90 days are purged by the purgeAuditLog cron job.
model AuditLog {
  id        String   @id @default(cuid())
  event     String   @db.VarChar(100)
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([createdAt])
  @@index([event, createdAt])
}

model BroadcastLog {
  id             String   @id @default(cuid())
  subject        String   @db.VarChar(200)
  bodyMarkdown   String   @db.Text
  recipientCount Int
  deliveredCount Int      @default(0)
  failedCount    Int      @default(0)
  failedIds      String[]
  sentAt         DateTime @default(now())
  sentToAll      Boolean
  targetIds      String[]

  @@index([sentAt])
}

// username maps to ADMIN_USERS env var, not a DB table.
// Renaming a username in env vars orphans its credentials - auth-verify
// rejects them. Off-boarding runbook must explicitly delete rows for
// removed admins.
model PasskeyCredential {
  id           String    @id @default(cuid())
  credentialId String    @unique
  publicKey    Bytes // COSE key, CBOR-encoded; maps to BYTEA
  counter      Int       @default(0)
  transports   String[]
  username     String
  label        String    @db.VarChar(100)
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([username])
}

// Rows are single-use: deleted atomically before verification.
// Cleanup cron purges rows where expiresAt < now().
model WebAuthnChallenge {
  id        String   @id // NOT @default(cuid()) - set explicitly in handler
  challenge String // base64url-encoded random bytes
  expiresAt DateTime

  @@index([expiresAt])
}

model PlayerCredential {
  id           String   @id @default(cuid())
  playerId     String   @unique
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([username])
}

model PlayerInvite {
  id         String    @id @default(cuid())
  playerId   String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  player     Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([expiresAt])
}
