    "otpauth": "^9.5.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "zod": "^4.3.6"
