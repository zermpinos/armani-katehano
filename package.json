{
  "name": "armani-katehano",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/strip-next-polyfills.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:build": "vitest run tests/build",
    "regenerate-csp-hashes": "node scripts/regenerate-csp-hashes.mjs"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "browserslist": {
    "production": [
      "chrome >= 96",
      "firefox >= 94",
      "safari >= 15.4",
      "edge >= 96"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@simplewebauthn/browser": "13.3.0",
    "@simplewebauthn/server": "13.3.1",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "dompurify": "^3.4.10",
    "marked": "^18.0.5",
    "next": "^16.2.9",
    "nodemailer": "^9.0.1",
    "otpauth": "^9.5.1",
    "pdf-parse": "^2.4.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.8.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "hono": ">=4.12.25",
    "@hono/node-server": ">=1.19.13",
    "postcss": "^8.5.10",
    "encoding-sniffer": "^1.0.2",
    "@babel/core": ">=7.29.7",
    "js-yaml": ">=4.2.0",
    "@typescript-eslint/typescript-estree": {
      "minimatch": {
        ".": "^10.2.5",
        "brace-expansion": "^5.0.6"
      }
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",

    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "@prisma/engines": true,
    "esbuild": true,
    "prisma": true,
    "sharp": true,
    "unrs-resolver": true
  }
}
