# Sanitized template - copy to .env.local and fill with real values.
# Never commit .env.local. All placeholders below are non-functional.
#
# Generate HMAC secrets locally with:
#     openssl rand -hex 32
#
# Every var that the codebase reads via process.env is listed here, grouped by
# category. Platform-supplied vars are commented for documentation only.


# =============================================================================
# Required app secrets - HMAC keys, passwords, tokens
# =============================================================================

ADMIN_PASSWORD=<ADMIN_LOGIN_PASSWORD>
COACH_PASSWORD=<COACH_LOGIN_PASSWORD>
COACH_SESSION_SECRET=<32_BYTE_RANDOM_HEX>
COACH_TOKEN=<COACH_PORTAL_TOKEN>
CRON_SECRET=<32_BYTE_RANDOM_HEX>
SESSION_SECRET=<32_BYTE_RANDOM_HEX>
PLAYER_SESSION_SECRET=<48_BYTE_RANDOM_HEX>
TURNSTILE_SECRET_KEY=<CLOUDFLARE_TURNSTILE_SERVER_KEY>

# Optional - gates the password+TOTP fallback path. If unset, fallback is disabled.
PASSKEY_FALLBACK_TOKEN=<32_BYTE_RANDOM_HEX>


# =============================================================================
# Service credentials - third-party / provider keys
# =============================================================================

BREVO_SMTP_USER=<BREVO_SMTP_LOGIN>
BREVO_SMTP_PASS=<BREVO_SMTP_PASSWORD>
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<CLOUDFLARE_TURNSTILE_SITE_KEY>


# =============================================================================
# App configuration - URLs, allowlists, slugs, recipients
# =============================================================================

ADMIN_ALERT_EMAIL=alerts@example.com
ADMIN_SLUG=<ADMIN_PATH_SLUG>
ADMIN_USERS=[{"username":"admin","passwordHash":"$2b$12$<BCRYPT_HASH>"}]
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
SCRAPE_HOSTNAME_ALLOWLIST=example.com,example.org


# =============================================================================
# Test-only (for local e2e runs)
# =============================================================================

E2E_ADMIN_USERNAME=<TEST_ADMIN_USERNAME>
E2E_ADMIN_PASSWORD=<TEST_ADMIN_PASSWORD>
PLAYWRIGHT_BASE_URL=http://localhost:3000


# =============================================================================
# Platform-supplied - do NOT set manually. Listed for documentation only.
# =============================================================================

# CI                              # set to "true" by GitHub Actions / CI runners
# NEXT_RUNTIME                    # "nodejs" | "edge" - set by Next.js runtime
# NODE_ENV                        # "development" | "production" | "test"
# VERCEL_AUTOMATION_BYPASS_SECRET # configured per-project in Vercel dashboard
# VERCEL_ENV                      # "production" | "preview" | "development"
# VERCEL_URL                      # deployment URL set by Vercel at build time
