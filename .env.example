# ─────────────────────────────────────────────────────────────────────────────
# .env.local  --  NEVER commit this file. Already in .gitignore.
# Copy each variable to: Vercel -> Project Settings -> Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key -- used server-side ONLY in /api/convert
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Secret admin password (20+ chars random string)
# Generate: node -e "console.log(require('crypto').randomBytes(20).toString('base64url'))"
ADMIN_PASSWORD=REPLACE_WITH_STRONG_RANDOM_PASSWORD

# HMAC signing secret for session cookies (64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING

# URL slug -- secret path for admin page: https://yoursite.com/admin/THIS_VALUE
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('base64url'))"
ADMIN_SLUG=REPLACE_WITH_RANDOM_SLUG

# ── Vercel KV (Redis) ─────────────────────────────────────────────────────────
# Auto-added when you connect a KV database in Vercel dashboard:
# Dashboard -> Storage -> Create KV -> Connect to Project
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Public env vars (safe to expose to browser) ───────────────────────────────
# Mirrors ADMIN_SLUG -- used client-side to show 404 for wrong slug
NEXT_PUBLIC_ADMIN_SLUG=REPLACE_WITH_SAME_SLUG_AS_ABOVE
